{
	"overrides": [
		{
			"files": "*.svelte",
			"options": {
				"parser": "svelte"
			}
		}
	],
	"plugins": [
		"prettier-plugin-svelte",
		"prettier-plugin-tailwindcss",
		"prettier-plugin-sort-json",
		"prettier-plugin-packagejson",
		"prettier-plugin-css-order",
		"prettier-plugin-organize-imports"
	],
	"printWidth": 100,
	"singleQuote": true,
	"tailwindStylesheet": "./src/routes/layout.css",
	"trailingComma": "none",
	"useTabs": true
}
